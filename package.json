{
  "name": "ghsecret",
  "version": "1.1.5",
  "description": "Push .env variables to GitHub Secrets & Variables",
  "type": "module",
  "bin": {
    "ghsecret": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barisdemirhan/ghsecret.git"
  },
  "homepage": "https://github.com/barisdemirhan/ghsecret",
  "bugs": {
    "url": "https://github.com/barisdemirhan/ghsecret/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "github",
    "secrets",
    "variables",
    "env",
    "cli",
    "gh",
    "dotenv"
  ],
  "author": "Barış Demirhan",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^13.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
